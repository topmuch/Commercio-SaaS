# ===== APPLICATION =====
# Application name
NEXT_PUBLIC_APP_NAME=Commercio SaaS

# Application URL (important for OAuth, webhooks, etc.)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Environment (development, staging, production)
NODE_ENV=production

# ===== DATABASE =====
# Database URL for Prisma (SQLite in this case)
DATABASE_URL="file:./db/dev.db"

# ===== AUTHENTICATION =====
# NextAuth.js secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=https://your-domain.com

# OAuth Providers (Optional)
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ===== EMAIL =====
# SMTP Configuration
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=Commercio <noreply@your-domain.com

# ===== STORAGE =====
# Upload provider (local, s3, cloudflare, etc.)
UPLOAD_PROVIDER=local

# AWS S3 (if using S3)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Cloudflare R2 (if using R2)
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-key
CLOUDFLARE_R2_BUCKET=your-bucket-name
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id

# ===== API KEYS & EXTERNAL SERVICES =====
# AI Services (if applicable)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Stripe (for payments)
STRIPE_PUBLIC_KEY=your-stripe-public-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Wave (for Senegal payments)
WAVE_API_KEY=your-wave-api-key
WAVE_SECRET_KEY=your-wave-secret-key

# ===== SECURITY =====
# Rate limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Session configuration
SESSION_MAX_AGE=604800000  # 7 days in milliseconds
SESSION_UPDATE_AGE=86400000  # 1 day in milliseconds

# ===== MONITORING & LOGGING =====
# Sentry (error tracking)
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=production

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# ===== CORS =====
# Allowed origins (comma-separated)
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ===== COOLIFY SPECIFIC =====
# Port (Coolify will set this automatically)
PORT=3000

# Build time
BUILD_TIME=2024-01-01T00:00:00Z

# ===== OPTIONAL: Redis (for caching/sessions) =====
REDIS_URL=redis://localhost:6379

# ===== OPTIONAL: Postgres (if migrating from SQLite) =====
# If you want to use PostgreSQL instead of SQLite:
# DATABASE_URL="postgresql://user:password@localhost:5432/commercio?schema=public"